<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WalNex" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_surface2</item>
        <item name="colorOutline">@color/divider_subtle</item>

        <item name="colorPrimary">@color/brand_gradient_start</item>
        <item name="colorSecondary">@color/brand_gradient_end</item>
        <item name="colorTertiary">@color/money_success</item>
        <item name="colorError">@color/money_danger</item>

        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.WalNex.HeadlineLarge</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.WalNex.TitleLarge</item>
    </style>

    <style name="TextAppearance.WalNex.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="TextAppearance.WalNex.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="Widget.WalNex.Button.Cta" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_cta_gradient_pill</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.WalNex.Button.Secondary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_secondary_button</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/splash_inspo_purple</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.WalNex.Button.SplashPrimary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_splash_button_primary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/splash_inspo_purple</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.WalNex.Button.SplashSecondary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_splash_button_secondary</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.WalNex.Button.AuthPrimary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_auth_primary_button</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.WalNex.SocialBadge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textColor">@color/auth_text_dark</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.WalNex.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_inspo_purple</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_empty</item>
        <item name="postSplashScreenTheme">@style/Theme.WalNex</item>
    </style>

    <style name="Theme.WalNex" parent="Base.Theme.WalNex" />

    <!-- White AlertDialog — full light dialog theme so it ignores the app's dark colorSurface -->
    <style name="WalNex.Dialog.White" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorPrimary">#643CC2</item>
        <item name="colorAccent">#643CC2</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>
    </style>
</resources>