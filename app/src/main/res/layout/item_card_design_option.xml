<?xml version="1.0" encoding="utf-8"?>
<!--
    Single card design option used in the AddNewCardActivity picker.
    MaterialCardView strokeWidth is toggled programmatically (3dp when selected, 0 when not).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDesignOption"
        android:layout_width="158dp"
        android:layout_height="99dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:strokeColor="#7343e7"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/imageDesignBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:contentDescription="Card design" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/textDesignName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textSize="12sp"
        android:textColor="@color/home_section_subtitle"
        android:gravity="center" />

</LinearLayout>