<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- Top section divider (thick-ish, shown above every section except the first) -->
    <View
        android:id="@+id/viewSectionDivider"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@color/history_section_divider"
        android:visibility="gone" />

    <!-- Section date label -->
    <TextView
        android:id="@+id/textSectionDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:paddingTop="18dp"
        android:paddingBottom="6dp"
        android:textColor="@color/history_section_label"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>