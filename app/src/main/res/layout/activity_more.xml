<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@+id/moreRoot"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_sheet_bg">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Screen Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_more"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/home_section_title"
                android:layout_marginBottom="24dp" />

            <!-- ===== SECTION 1: Main Options ===== -->

            <!-- Pay Bills Row -->
            <LinearLayout
                android:id="@+id/rowPayBills"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <!-- Icon Background -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_pay_bills"
                        android:contentDescription="Pay Bills"
                        app:tint="#5b31be" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/more_pay_bills"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

            <!-- Divider -->
            <include layout="@layout/item_history_row_divider" />

            <!-- Transfer Row -->
            <LinearLayout
                android:id="@+id/rowTransfer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon_blue">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_transfer"
                        android:contentDescription="Transfer"
                        app:tint="#0064ca" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/home_action_transfer"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

            <!-- Divider -->
            <include layout="@layout/item_history_row_divider" />

            <!-- Topup Row -->
            <LinearLayout
                android:id="@+id/rowTopup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon_green">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_topup"
                        android:contentDescription="Topup"
                        app:tint="#009d56" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/home_action_topup"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

            <!-- Divider -->
            <include layout="@layout/item_history_row_divider" />

            <!-- Withdraw Row -->
            <LinearLayout
                android:id="@+id/rowWithdraw"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon_red">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_withdraw"
                        android:contentDescription="Withdraw"
                        app:tint="#d02f30" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/home_action_withdraw"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

            <!-- Divider -->
            <include layout="@layout/item_history_row_divider" />

            <!-- Analytics Row -->
            <LinearLayout
                android:id="@+id/rowAnalytics"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon_pink">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_analytics"
                        android:contentDescription="Analytics"
                        app:tint="#cc2223" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/more_analytics"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

            <!-- ===== SECTION DIVIDER ===== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@color/home_divider" />

            <!-- ===== SECTION 2: Support Options ===== -->

            <!-- Help Row -->
            <LinearLayout
                android:id="@+id/rowHelp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon_yellow">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_help"
                        android:contentDescription="Help"
                        app:tint="#a16310" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/more_help"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

            <!-- Divider -->
            <include layout="@layout/item_history_row_divider" />

            <!-- Contact Us Row -->
            <LinearLayout
                android:id="@+id/rowContactUs"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon_teal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_contact_us"
                        android:contentDescription="Contact Us"
                        app:tint="#009887" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/more_contact_us"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

            <!-- Divider -->
            <include layout="@layout/item_history_row_divider" />

            <!-- About Row -->
            <LinearLayout
                android:id="@+id/rowAbout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_more_icon_violet">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_about"
                        android:contentDescription="About"
                        app:tint="#643cc2" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/more_about"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="15sp"
                    android:textColor="@color/home_section_title"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate"
                    app:tint="@color/home_section_subtitle" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_nav_bar"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Home Tab -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/navIconHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                android:contentDescription="@string/nav_home"
                app:tint="@color/nav_unselected" />

            <TextView
                android:id="@+id/navLabelHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/nav_home"
                android:textColor="@color/nav_unselected"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- History Tab -->
        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/navIconHistory"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_history"
                android:contentDescription="@string/nav_history"
                app:tint="@color/nav_unselected" />

            <TextView
                android:id="@+id/navLabelHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/nav_history"
                android:textColor="@color/nav_unselected"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Cards Tab -->
        <LinearLayout
            android:id="@+id/navCards"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/navIconCards"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_cards"
                android:contentDescription="@string/nav_cards"
                app:tint="@color/nav_unselected" />

            <TextView
                android:id="@+id/navLabelCards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/nav_cards"
                android:textColor="@color/nav_unselected"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- More Tab (SELECTED) -->
        <LinearLayout
            android:id="@+id/navMore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/navIconMore"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_more"
                android:contentDescription="@string/nav_more"
                app:tint="@color/nav_selected" />

            <TextView
                android:id="@+id/navLabelMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/nav_more"
                android:textColor="@color/nav_selected"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>