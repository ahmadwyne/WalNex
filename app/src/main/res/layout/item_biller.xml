<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_transaction_row"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Category icon with colored background -->
    <FrameLayout
        android:id="@+id/frameItemBillerIcon"
        android:layout_width="48dp"
        android:layout_height="48dp">

        <ImageView
            android:id="@+id/imageItemBillerIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:scaleType="fitCenter"/>
    </FrameLayout>

    <!-- Category name + account number -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textItemBillerCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="#1A1A2E"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textItemBillerAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="#8A8A9A"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Amount + due date -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textItemBillerAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="#1A1A2E"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textItemBillerDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="#8A8A9A"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Chevron -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="10dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_chevron_right"
        app:tint="#BDBDBD"/>

</LinearLayout>
