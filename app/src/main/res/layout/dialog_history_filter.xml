<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_filter_dialog"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/bg_filter_accent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/history_filter_title"
            android:textColor="@color/analytics_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/history_filter_subtitle"
            android:textColor="@color/analytics_muted"
            android:textSize="12sp"
            android:fontFamily="@font/plus_jakarta_sans" />

        <RadioGroup
            android:id="@+id/radioGroupFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rowFilterAll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_filter_option"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true">

                <RadioButton
                    android:id="@+id/radioFilterAll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_filter_all"
                    android:textColor="@color/analytics_title"
                    android:textSize="13sp"
                    android:buttonTint="@color/analytics_accent"
                    android:fontFamily="@font/plus_jakarta_sans" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowFilterIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_filter_option"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true">

                <RadioButton
                    android:id="@+id/radioFilterIn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_filter_in"
                    android:textColor="@color/analytics_title"
                    android:textSize="13sp"
                    android:buttonTint="@color/analytics_accent"
                    android:fontFamily="@font/plus_jakarta_sans" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowFilterOut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filter_option"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true">

                <RadioButton
                    android:id="@+id/radioFilterOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_filter_out"
                    android:textColor="@color/analytics_title"
                    android:textSize="13sp"
                    android:buttonTint="@color/analytics_accent"
                    android:fontFamily="@font/plus_jakarta_sans" />
            </LinearLayout>
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textFilterReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/history_filter_reset"
                android:textColor="@color/analytics_muted"
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:padding="8dp" />

            <TextView
                android:id="@+id/textFilterCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/history_filter_cancel"
                android:textColor="@color/analytics_muted"
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:padding="8dp" />

            <TextView
                android:id="@+id/buttonFilterApply"
                android:layout_width="88dp"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_splash_button_primary"
                android:gravity="center"
                android:text="@string/history_filter_apply"
                android:textColor="@color/splash_inspo_purple"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
