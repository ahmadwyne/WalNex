<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/contactRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_sheet_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/textContactBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_back"
                android:textColor="@color/home_view_all"
                android:textSize="14sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:paddingVertical="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/contact_title"
                android:textColor="@color/home_section_title"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/contact_intro"
                android:textColor="@color/home_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_phone_label"
                    android:textColor="@color/home_section_subtitle"
                    android:textSize="12sp"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:id="@+id/textContactPhoneValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_phone"
                    android:textColor="@color/home_section_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:paddingTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/contact_email_label"
                    android:textColor="@color/home_section_subtitle"
                    android:textSize="12sp"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:id="@+id/textContactEmailValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_email"
                    android:textColor="@color/home_section_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:paddingTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/contact_hours_label"
                    android:textColor="@color/home_section_subtitle"
                    android:textSize="12sp"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_hours"
                    android:textColor="@color/home_section_title"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:paddingTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/contact_address_label"
                    android:textColor="@color/home_section_subtitle"
                    android:textSize="12sp"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_address"
                    android:textColor="@color/home_section_title"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>