<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/analyticsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_analytics_gradient">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/analytics_title"
                    android:textColor="@color/analytics_title"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analytics_chip"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="@string/analytics_live"
                    android:textColor="@color/analytics_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/analytics_subtitle"
                android:textColor="@color/analytics_muted"
                android:textSize="14sp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:id="@+id/textAnalyticsUpdated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/analytics_updated_default"
                android:textColor="@color/analytics_muted"
                android:textSize="12sp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_analytics_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_money_in"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:id="@+id/textKpiInValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="PKR 0.00"
                            android:textColor="@color/analytics_title"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/analytics_period_week"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_analytics_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_money_out"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:id="@+id/textKpiOutValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="PKR 0.00"
                            android:textColor="@color/analytics_title"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/analytics_period_week"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_analytics_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_net_flow"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:id="@+id/textKpiNetValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="+PKR 0.00"
                            android:textColor="@color/tx_credit_text"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/analytics_period_week"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_analytics_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_tx_count"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:id="@+id/textKpiCountValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="0"
                            android:textColor="@color/analytics_title"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/analytics_period_week"
                            android:textColor="@color/analytics_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_analytics_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analytics_chart_title"
                    android:textColor="@color/analytics_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/analytics_chart_subtitle"
                    android:textColor="@color/analytics_muted"
                    android:textSize="12sp"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="140dp"
                            android:background="@drawable/bg_analytics_bar_track">

                            <View
                                android:id="@+id/barDay0"
                                android:layout_width="match_parent"
                                android:layout_height="12dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_analytics_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textDay0"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Mon"
                            android:textColor="@color/analytics_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="140dp"
                            android:background="@drawable/bg_analytics_bar_track">

                            <View
                                android:id="@+id/barDay1"
                                android:layout_width="match_parent"
                                android:layout_height="12dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_analytics_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textDay1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Tue"
                            android:textColor="@color/analytics_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="140dp"
                            android:background="@drawable/bg_analytics_bar_track">

                            <View
                                android:id="@+id/barDay2"
                                android:layout_width="match_parent"
                                android:layout_height="12dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_analytics_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textDay2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Wed"
                            android:textColor="@color/analytics_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="140dp"
                            android:background="@drawable/bg_analytics_bar_track">

                            <View
                                android:id="@+id/barDay3"
                                android:layout_width="match_parent"
                                android:layout_height="12dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_analytics_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textDay3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Thu"
                            android:textColor="@color/analytics_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="140dp"
                            android:background="@drawable/bg_analytics_bar_track">

                            <View
                                android:id="@+id/barDay4"
                                android:layout_width="match_parent"
                                android:layout_height="12dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_analytics_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textDay4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Fri"
                            android:textColor="@color/analytics_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="140dp"
                            android:background="@drawable/bg_analytics_bar_track">

                            <View
                                android:id="@+id/barDay5"
                                android:layout_width="match_parent"
                                android:layout_height="12dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_analytics_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textDay5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Sat"
                            android:textColor="@color/analytics_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="140dp"
                            android:background="@drawable/bg_analytics_bar_track">

                            <View
                                android:id="@+id/barDay6"
                                android:layout_width="match_parent"
                                android:layout_height="12dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_analytics_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textDay6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Sun"
                            android:textColor="@color/analytics_muted"
                            android:textSize="11sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_analytics_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analytics_top_recipients"
                    android:textColor="@color/analytics_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <TextView
                    android:id="@+id/textTopEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/analytics_top_empty"
                    android:textColor="@color/analytics_muted"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textTopName1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=""
                            android:textColor="@color/analytics_title"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:id="@+id/textTopAmount1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/analytics_muted"
                            android:textSize="14sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textTopName2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=""
                            android:textColor="@color/analytics_title"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:id="@+id/textTopAmount2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/analytics_muted"
                            android:textSize="14sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textTopName3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=""
                            android:textColor="@color/analytics_title"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/plus_jakarta_sans" />

                        <TextView
                            android:id="@+id/textTopAmount3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/analytics_muted"
                            android:textSize="14sp"
                            android:fontFamily="@font/plus_jakarta_sans" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>