<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/phoneAuthRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_surface_white">

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="0dp"
        android:layout_height="270dp"
        android:background="@drawable/bg_auth_top_panel"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/textBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="@string/auth_back"
                android:textColor="@color/splash_inspo_purple"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/archivo_black"
                android:gravity="center"
                android:text="@string/walnex_wordmark"
                android:textColor="@color/splash_inspo_purple"
                android:textSize="22sp" />

            <View
                android:layout_width="52dp"
                android:layout_height="1dp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imageTopIllustration"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:contentDescription="@string/content_phone_illustration"
            android:scaleType="fitCenter"
            android:src="@drawable/phone" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topPanel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="16dp"
            android:paddingEnd="22dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/textAuthModeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/auth_enter_mobile_title"
                android:textColor="@color/auth_text_dark"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/auth_mobile_label"
                android:textColor="@color/auth_text_dark"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_auth_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <Spinner
                    android:id="@+id/spinnerCountryCode"
                    android:layout_width="86dp"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:popupBackground="@drawable/bg_auth_spinner_popup"
                    android:spinnerMode="dropdown" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="26dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@color/auth_border" />

                <EditText
                    android:id="@+id/editPhoneNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/auth_mobile_hint"
                    android:importantForAutofill="no"
                    android:inputType="phone"
                    android:maxLines="1"
                    android:textColor="@color/auth_text_dark"
                    android:textColorHint="@color/auth_text_muted"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textAuthHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text=""
                android:textColor="@color/auth_text_muted"
                android:textSize="12sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressSendOtp"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonContinue"
                style="@style/Widget.WalNex.Button.AuthPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/auth_continue" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/auth_or_continue_using"
                android:textColor="@color/auth_text_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_auth_social"
                    android:gravity="center"
                    android:text="f"
                    android:textAppearance="@style/TextAppearance.WalNex.SocialBadge"
                    android:textColor="#1877F2" />

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_auth_social"
                    android:gravity="center"
                    android:text="G"
                    android:textAppearance="@style/TextAppearance.WalNex.SocialBadge"
                    android:textColor="#DB4437" />

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_auth_social"
                    android:gravity="center"
                    android:text="A"
                    android:textAppearance="@style/TextAppearance.WalNex.SocialBadge"
                    android:textColor="#000000" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
