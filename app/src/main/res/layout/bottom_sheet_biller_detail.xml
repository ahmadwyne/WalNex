<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_filter_accent"/>

    <!-- Header: icon + name/type + Done -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:id="@+id/frameDetailIcon"
            android:layout_width="56dp"
            android:layout_height="56dp">

            <ImageView
                android:id="@+id/imageDetailIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:scaleType="fitCenter"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="#1A1A2E"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textDetailType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="#8A8A9A"
                android:textSize="13sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnDetailDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:fontFamily="@font/plus_jakarta_sans"
            android:padding="6dp"
            android:text="Done"
            android:textColor="#0064CA"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0EDFF"/>

    <!-- Due Amount label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="Due Amount"
        android:textColor="#8A8A9A"
        android:textSize="12sp"/>

    <!-- Due amount box -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_bill_due_box"
        android:padding="16dp">

        <TextView
            android:id="@+id/textDetailAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="#CC2223"
            android:textSize="24sp"
            android:textStyle="bold"/>
    </FrameLayout>

    <!-- Due date + Reg no row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal">

        <!-- Due Date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Due Date"
                android:textColor="#8A8A9A"
                android:textSize="12sp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_detail_info_box"
                android:padding="12dp">

                <TextView
                    android:id="@+id/textDetailDueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </FrameLayout>
        </LinearLayout>

        <View
            android:layout_width="10dp"
            android:layout_height="1dp"/>

        <!-- Reg. No. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Reg. No."
                android:textColor="#8A8A9A"
                android:textSize="12sp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_detail_info_box"
                android:padding="12dp">

                <TextView
                    android:id="@+id/textDetailRegNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Secure Payment button -->
    <LinearLayout
        android:id="@+id/btnSecurePayment"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_secure_pay_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_lock"
            app:tint="#37107E"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Secure Payment"
            android:textColor="#37107E"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
