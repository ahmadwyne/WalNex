<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/aboutRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_sheet_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/textAboutBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_back"
                android:textColor="@color/home_view_all"
                android:textSize="14sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:paddingVertical="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/about_title"
                android:textColor="@color/home_section_title"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/about_body"
                android:textColor="@color/home_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/about_body_second"
                android:textColor="@color/home_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/about_faq_title"
                android:textColor="@color/home_section_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/about_faq_q1"
                android:textColor="@color/home_section_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/about_faq_a1"
                android:textColor="@color/home_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/about_faq_q2"
                android:textColor="@color/home_section_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/about_faq_a2"
                android:textColor="@color/home_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/about_faq_q3"
                android:textColor="@color/home_section_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/about_faq_a3"
                android:textColor="@color/home_text_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>