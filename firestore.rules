rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userFieldsValid() {
      return request.resource.data.keys().hasOnly([
        'fullName',
        'phoneE164',
        'photoUrl',
        'status',
        'email',
        'createdAt',
        'updatedAt',
        'lastLoginAt'
      ]);
    }

    function walletFieldsValid() {
      return request.resource.data.keys().hasOnly([
        'balance',
        'currency',
        'updatedAt'
      ])
      && request.resource.data.balance is number
      && request.resource.data.currency is string
      && request.resource.data.updatedAt is timestamp;
    }

    function txFieldsValid() {
      return request.resource.data.keys().hasOnly([
        'txId',
        'senderUid',
        'senderName',
        'senderPhone',
        'recipientUid',
        'recipientPhone',
        'recipientName',
        'amount',
        'currency',
        'status',
        'type',
        'createdAt'
      ])
      && request.resource.data.txId is string
      && request.resource.data.senderUid is string
      && request.resource.data.recipientUid is string
      && request.resource.data.amount is number
      && request.resource.data.currency is string
      && request.resource.data.status is string
      && request.resource.data.type is string
      && (!('senderName' in request.resource.data)
        || request.resource.data.senderName is string
        || request.resource.data.senderName == null)
      && (!('senderPhone' in request.resource.data)
        || request.resource.data.senderPhone is string
        || request.resource.data.senderPhone == null)
      && (!('recipientName' in request.resource.data)
        || request.resource.data.recipientName is string
        || request.resource.data.recipientName == null)
      && (!('recipientPhone' in request.resource.data)
        || request.resource.data.recipientPhone is string
        || request.resource.data.recipientPhone == null)
      && (!('createdAt' in request.resource.data)
        || request.resource.data.createdAt is timestamp);
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
        && userFieldsValid()
        && (!('phoneE164' in request.resource.data)
          || (request.resource.data.phoneE164 is string && request.resource.data.phoneE164.size() > 0));

      allow update: if isSelf(uid)
        && userFieldsValid()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'fullName',
          'photoUrl',
          'email',
          'createdAt',
          'updatedAt',
          'lastLoginAt',
          'phoneE164',
          'status'
        ])
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        && (!('phoneE164' in resource.data) || request.resource.data.phoneE164 == resource.data.phoneE164)
        && (!('status' in resource.data) || request.resource.data.status == resource.data.status);

      allow delete: if false;
    }

    match /wallets/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && walletFieldsValid();
      allow delete: if false;
    }

    match /users/{uid}/transactions/{txId} {
      allow read: if isSelf(uid);
      allow create: if isSignedIn() && txFieldsValid();
      allow update, delete: if false;
    }

    match /ledger/{uid}/entries/{entryId} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    match /transactions/{txId} {
      allow read: if isSignedIn()
        && (
          resource.data.senderUid == request.auth.uid
          || resource.data.receiverUid == request.auth.uid
        );
      allow write: if false;
    }

    match /notifications/{uid}/items/{notifId} {
      allow read: if isSelf(uid);
      allow create, delete: if false;
      allow update: if isSelf(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read'])
        && request.resource.data.read is bool;
    }

    match /devices/{uid}/tokens/{tokenId} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid)
        && request.resource.data.keys().hasOnly(['fcmToken', 'platform', 'createdAt', 'lastSeenAt'])
        && request.resource.data.fcmToken is string
        && request.resource.data.platform == 'android';
      allow delete: if isSelf(uid);
    }

    match /phones/{phoneE164} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
